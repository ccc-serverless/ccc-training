{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "build": {
    "env": {
      "NODE_OPTIONS": "--openssl-legacy-provider",
      "REACT_APP_ENV": "PROD",
      "REACT_APP_API_BASE_URL": "https://api.ccc.training"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
